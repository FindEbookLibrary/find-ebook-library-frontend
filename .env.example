# 환경 변수 예제 파일
# 실제 사용 시 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# .env.local 파일은 .gitignore에 포함되어 있어 Git에 커밋되지 않습니다.

# Next.js 환경 변수 규칙:
# - NEXT_PUBLIC_ 접두사: 브라우저(클라이언트)에서 접근 가능
# - 접두사 없음: 서버 사이드에서만 접근 가능 (더 안전)

# 백엔드 API 서버 주소 (클라이언트에서 접근)
# 개발 환경: http://localhost:8080/api/v1
# 운영 환경: https://api.findebook.com/api/v1 (예정)
# Next.js의 rewrites 기능을 사용하려면 /api/v1로 설정
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# UI 개발 중에는 mock 데이터를 기본으로 사용합니다.
# 백엔드 연결 확인 시 false로 바꿔 실제 API 응답을 확인할 수 있습니다.
NEXT_PUBLIC_USE_MOCK=true

# 도서관 정보나루 API 인증 키 (클라이언트에서 접근)
# http://data4library.kr 에서 발급받은 인증 키를 입력하세요.
# NEXT_PUBLIC_ 접두사: 브라우저에서 접근 가능 (공개 API 키이므로 안전)
NEXT_PUBLIC_LIBRARY_API_KEY=your_library_api_key_here

# 클라이언트에서 접근 가능한 환경 변수 (필요시)
# 예: 구글 애널리틱스 ID 등
# NEXT_PUBLIC_GA_ID=your_ga_id_here

# Next.js 환경
NODE_ENV=development
