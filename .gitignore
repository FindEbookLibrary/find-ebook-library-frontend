# 프로젝트에서 Git 추적을 제외할 파일 및 디렉토리 목록

# 의존성 패키지 디렉토리
node_modules/

# 빌드 결과물
dist/
build/
.next/

# 환경 변수 파일 (민감한 정보 포함)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 로그 파일
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 에디터 설정 파일
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 테스트 커버리지
coverage/

# 임시 파일
*.tmp
*.temp
